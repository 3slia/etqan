/* Page Header Reusable Styles */
.page-header {
  padding: 180px 0 80px;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  text-align: center;
  border-bottom: 1px solid var(--border-color);
}

.page-title {
  font-size: 3.5rem;
  margin-bottom: 1rem;
  color: var(--secondary-color);
}

.page-desc {
  font-size: 1.2rem;
  color: var(--secondary-text);
  max-width: 600px;
  margin: 0 auto;
}

/* Split Layout */
.services-split-section {
  background-color: var(--bg-main);
  position: relative;
}

.services-split-layout {
  display: flex;
  gap: 4rem;
  align-items: flex-start;
}

/* Sidebar Navigation */
.services-sidebar {
  flex: 0 0 350px;
  position: sticky;
  top: 120px;
  background: #fff;
  border-radius: 20px;
  padding: 2.5rem;
  box-shadow: 0 15px 40px rgba(0,0,0,0.03);
  border: 1px solid rgba(0,0,0,0.04);
}

.sidebar-title {
  font-size: 1.4rem;
  color: var(--secondary-color);
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-color);
}

.services-menu {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.services-menu li {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.2rem 1.5rem;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  color: var(--secondary-text);
  background: transparent;
}

.services-menu li:hover {
  background: rgba(18, 187, 192, 0.03);
  color: var(--primary-color);
}

.services-menu li.active {
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 10px 20px rgba(18, 187, 192, 0.2);
}

.service-number {
  font-family: var(--font-english);
  font-weight: 700;
  font-size: 1.1rem;
  opacity: 0.5;
}

.services-menu li.active .service-number {
  opacity: 0.8;
}

.service-name {
  font-weight: 700;
  font-size: 1.1rem;
}

/* Active Content Area */
.active-service-content {
  flex: 1;
  min-height: 500px;
  position: relative;
}

.service-detail-view {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.service-detail-view.show {
  position: relative;
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.service-header-clean {
  margin-bottom: 3rem;
}

.service-icon-large {
  width: 90px;
  height: 90px;
  background: rgba(18, 187, 192, 0.05);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-color);
  margin-bottom: 2rem;
}

.service-massive-title {
  font-size: 3rem;
  font-weight: 800;
  color: var(--secondary-color);
  margin-bottom: 1.5rem;
  line-height: 1.3;
}

.service-elegant-desc {
  font-size: 1.25rem;
  color: var(--secondary-text);
  line-height: 1.8;
  max-width: 700px;
}

/* Features List */
.service-features-grid {
  background: #fff;
  border-radius: 20px;
  padding: 3rem;
  border: 1px solid rgba(0,0,0,0.04);
  margin-bottom: 3rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.02);
}

.features-heading {
  font-size: 1.4rem;
  color: var(--secondary-color);
  margin-bottom: 2rem;
}

.features-clean-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  list-style: none;
  padding: 0;
}

.features-clean-list li {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.1rem;
  color: var(--secondary-text);
  font-weight: 500;
}

.feature-bullet {
  width: 8px;
  height: 8px;
  background: var(--primary-color);
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4px rgba(18, 187, 192, 0.1);
}

/* CTA */
.service-cta {
  display: flex;
  gap: 1rem;
}

@media (max-width: 992px) {
  .services-split-layout {
    flex-direction: column;
    gap: 3rem;
  }
  
  .services-sidebar {
    flex: none;
    width: 100%;
    position: relative;
    top: 0;
    padding: 1.5rem;
  }

  .service-massive-title {
    font-size: 2.2rem;
  }

  .service-features-grid {
    padding: 2rem;
  }
}
